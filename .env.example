# Supabase (https://supabase.com/dashboard) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Analytics 4 — https://analytics.google.com → Admin → Datastrømmer → Web → målings-ID (G-…). Valgfritt; uten verdi lastes ikke gtag.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# I Supabase: Authentication → URL Configuration
#   • Site URL: f.eks. http://localhost:3000 (eller produksjonsdomene)
#   • Redirect URLs: må inkludere http://localhost:3000/auth/callback og https://<ditt-domene>/auth/callback
# Glemt passord: resetPasswordForEmail redirecter hit; malen «Reset password» (Authentication → Email Templates)
#   må bruke tillatt redirect — samme origin + /auth/callback?next=… (appen setter next=/tilbakestill-passord).
# NEXT_PUBLIC_APP_URL bør matche produksjonsdomene der du trenger absolutte URL-er andre steder i appen (f.eks. OG);
#   glemt-passord bruker window.location.origin på klient for redirectTo.

# Stripe (Developers → API keys, test mode) — produktpriser fra Product catalog
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_PRICE_SOLO=price_...
# STRIPE_PRICE_FAMILY=price_...
#
# STRIPE_WEBHOOK_SECRET=whsec_…  (Signing secret fra Stripe Dashboard → Developers → Webhooks → velg endepunkt)
# Customer Portal (knapp «Administrer abonnement» på /konto/betalinger) bruker samme STRIPE_SECRET_KEY; aktiver portal i Stripe Dashboard → Settings → Billing → Customer portal.
#
# Uten Stripe CLI (lokalt): Stripe når ikke http://localhost. Bruk en HTTPS-tunnel til dev-serveren, f.eks.:
#   • ngrok: https://ngrok.com/docs  →  ngrok http 3000  (eller tilsvarende for Cloudflare Tunnel, localtunnel)
# Legg webhook i Dashboard med URL:  https://<din-tunnel-host>/api/stripe/webhook
# Velg hendelser (minst): checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# Kopier «Signing secret» (whsec_…) inn i STRIPE_WEBHOOK_SECRET over.
# For at Checkout success/cancel skal lande riktig via tunnel: sett NEXT_PUBLIC_APP_URL til samme https://<din-tunnel-host>
# (ellers brukes localhost i success_url).
#
# Enklest uten tunnel: deploy til Vercel preview/staging og bruk den offentlige URL-en som webhook + NEXT_PUBLIC_APP_URL.

# Abonnementshåndheving (API + skrivebeskyttet app + middleware-redirect til /konto/betalinger).
# Uten denne eller satt til noe annet enn "true": ingen redirect og API tillater mer — men etter at migrasjon 007 er kjørt i Supabase,
# blokkerer RLS fortsatt lagring uten gyldig user_subscription (uavhengig av dette flagget). Sett true i prod etter migrasjon.
# Når true: uten aktiv prøveperiode/abonnement (active / trialing / past_due) eller legacy_grandfathered: redirect til betaling for app-sider; /konto/** er unntatt; API 403 der det sjekkes.
# Go-live: deploy kode → kjør supabase/migrations/007_subscription_gate.sql → sett SUBSCRIPTION_ENFORCEMENT_ENABLED=true.
# SUBSCRIPTION_ENFORCEMENT_ENABLED=true

# Prøveperiode ved Checkout (dager). Default 14; sett 0 for å ikke legge inn prøveperiode i Checkout (da bruker du ev. prøve kun fra Stripe-pris).
# STRIPE_SUBSCRIPTION_TRIAL_DAYS=14
#
# Utvidet prøve for utvalgte brukere (kommaseparerte e-poster, små/store bokstaver likegyldig).
# Valgfritt: STRIPE_EXTENDED_TRIAL_USER_IDS=uuid-fra-Supabase-Auth (samme som user_id) hvis e-post ikke treffer.
# Gjelder ved nye Checkout-økter: de får STRIPE_EXTENDED_TRIAL_DAYS (default 183 ≈ 6 mnd). Eksisterende abonnement i Stripe endres ikke — forleng prøve der eller kjør Checkout på nytt.
# Sett verdien i Vercel / hemmelig .env — ikke commit ekte kundeadresser til Git.
# STRIPE_EXTENDED_TRIAL_EMAILS=vip@example.com,annet@firma.no
# STRIPE_EXTENDED_TRIAL_USER_IDS=
# STRIPE_EXTENDED_TRIAL_DAYS=183

# Valgfritt — brukes av Checkout success/cancel-URL, Open Graph / canonical på landing (default localhost:3000)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Webhook må oppdatere user_subscription — Project Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=

# Daglig kursoppdatering for kurskoblede aksjer (cron /api/cron/investment-quotes). Sett i Vercel og match Authorization.
# CRON_SECRET=

# Vercel Cron (vercel.json): 0 15 * * * UTC ≈ kl. 16:00 norsk vintertid for aksjekurs-jobb

# Kursoppslag (Investering) — gratis API-nøkkel: https://finnhub.io/register
# FINNHUB_API_KEY=

# EnkelExcel AI (OpenAI) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# Valgfritt — default i kode er gpt-4o-mini; sett f.eks. gpt-5.4-mini eller gpt-5.4-nano for lavere kostnad
# OPENAI_MODEL=
# Valgfritt — sampling-temperatur 0–2 for chat (default 0.12; lavere = mer konsistent mot datagrunnlag og svarstruktur)
# OPENAI_TEMPERATURE=0.12
# Valgfritt — maks meldinger per bruker per måned (default 100)
# AI_MONTHLY_MESSAGE_LIMIT=
# Ekstra AI-meldinger (Stripe engangspris — opprett produkt/pris i Stripe Dashboard)
# STRIPE_PRICE_AI_CREDITS_100=price_...
# Valgfritt — antall meldinger i kjøpspakken (default 100)
# AI_BONUS_PACK_CREDITS=100
# Valgfritt — pris vist i UI (NOK, default 29)
# NEXT_PUBLIC_AI_BONUS_PRICE_NOK=29
