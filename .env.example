# Supabase (https://supabase.com/dashboard) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# I Supabase: Authentication → URL Configuration — sett Site URL (f.eks. http://localhost:3000)
# og Redirect URLs: http://localhost:3000/auth/callback (legg til produksjons-URL ved deploy).

# Stripe (Developers → API keys, test mode) — produktpriser fra Product catalog
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_PRICE_SOLO=price_...
# STRIPE_PRICE_FAMILY=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...   (fra Stripe CLI: stripe listen --forward-to ...)

# Valgfritt — brukes av Checkout success/cancel-URL (default localhost:3000)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Webhook må oppdatere user_subscription — Project Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=

# Kursoppslag (Investering) — gratis API-nøkkel: https://finnhub.io/register
# FINNHUB_API_KEY=

# EnkelExcel AI (OpenAI) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# Valgfritt — default i kode er gpt-4o-mini; sett f.eks. gpt-5.4-mini eller gpt-5.4-nano for lavere kostnad
# OPENAI_MODEL=
